@page "/access"
@model AccessModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Secure Access | Find My Path</title>
    <link rel="icon" type="image/png" href="~/favicon.png" />
    <link rel="stylesheet" href="~/access.css" asp-append-version="true" />
</head>
<body>
    <main class="access-page">
        <div class="access-backdrop access-backdrop-one" aria-hidden="true"></div>
        <div class="access-backdrop access-backdrop-two" aria-hidden="true"></div>

        <section class="access-card" aria-labelledby="access-title">
            <header class="access-header">
                <div class="client-mark" aria-label="Health Net Canada">
                    <span class="client-mark-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" focusable="false">
                            <path d="M12 2.75 20 6v5.25c0 5.1-3.42 8.77-8 10-4.58-1.23-8-4.9-8-10V6l8-3.25Z" />
                            <path d="M12 7.3v7.4M8.3 11h7.4" />
                        </svg>
                    </span>
                    <span>Health Net Canada</span>
                </div>
                <span class="environment-badge">Private demonstration</span>
            </header>

            <div class="access-content">
                <div class="lock-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <rect x="5" y="10" width="14" height="11" rx="2.5" />
                        <path d="M8.5 10V7.5a3.5 3.5 0 0 1 7 0V10M12 14.5v2.25" />
                    </svg>
                </div>

                <p class="eyebrow">Restricted proof-of-concept access</p>
                <h1 id="access-title">Welcome to Find My Path</h1>
                <p class="access-summary">
                    This private proof of concept was prepared by <strong>Sitefluence Consulting Inc.</strong>
                    for <strong>Health Net Canada</strong>. It is provided solely for authorized evaluation
                    and demonstration purposes.
                </p>
                <p class="access-instruction">
                    Access is limited to authorized reviewers and invited participants. Enter the access PIN
                    issued to you to continue.
                </p>

                <form method="post" class="access-form">
                    <input asp-for="ReturnUrl" type="hidden" />

                    <div class="field-group">
                        <label asp-for="Pin">Access PIN</label>
                        <div class="pin-field @(Model.InvalidPin ? "pin-field-invalid" : null)">
                            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                <rect x="5" y="10" width="14" height="11" rx="2.5" />
                                <path d="M8.5 10V7.5a3.5 3.5 0 0 1 7 0V10" />
                            </svg>
                            <input asp-for="Pin"
                                   type="password"
                                   maxlength="128"
                                   autocomplete="current-password"
                                   autofocus
                                   aria-describedby="pin-help @(Model.InvalidPin ? "pin-error" : null)"
                                   aria-invalid="@(Model.InvalidPin ? "true" : "false")"
                                   placeholder="Enter your PIN" />
                        </div>
                        <span id="pin-help" class="field-help">Your PIN is case-sensitive.</span>
                        @if (Model.InvalidPin)
                        {
                            <span id="pin-error" class="pin-error" role="alert">
                                The PIN entered was not recognized. Please verify it and try again.
                            </span>
                        }
                    </div>

                    <button type="submit" class="continue-button">
                        <span>Continue securely</span>
                        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                            <path d="m9 18 6-6-6-6" />
                        </svg>
                    </button>
                </form>
            </div>

            <footer class="access-footer">
                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path d="M12 2.75 20 6v5.25c0 5.1-3.42 8.77-8 10-4.58-1.23-8-4.9-8-10V6l8-3.25Z" />
                    <path d="m8.7 12 2.1 2.1 4.6-4.6" />
                </svg>
                <span>Authorized access only</span>
                <span class="footer-separator" aria-hidden="true">&middot;</span>
                <span>Proof-of-concept environment</span>
            </footer>
        </section>

        <p class="prepared-by">Prepared by Sitefluence Consulting Inc.</p>
    </main>
</body>
</html>
