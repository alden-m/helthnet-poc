@namespace FindMyPath.Poc.Components.Wizard
@inject IJSRuntime JS

<div class="roadmap">
    <div class="roadmap-hero">
        <div class="roadmap-hero-top">
            <div class="roadmap-hero-title">
                <svg viewBox="0 0 16 16" class="hero-check" aria-hidden="true"><path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0m-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/></svg>
                <span>Your Personalized Pathway</span>
            </div>
            <span class="draft-badge">Draft · AI-generated, pending advisor review</span>
        </div>

        @if (!string.IsNullOrWhiteSpace(Result.Roadmap?.Summary))
        {
            <p class="roadmap-hero-sub">@Result.Roadmap!.Summary</p>
        }

        <div class="stat-chips">
            <div class="stat-chip">
                <span class="stat-label">Profession</span>
                <span class="stat-val">@(string.IsNullOrWhiteSpace(Answers.Profession) ? "—" : Answers.Profession)</span>
            </div>
            <div class="stat-chip">
                <span class="stat-label">Target Province</span>
                <span class="stat-val">@(string.IsNullOrWhiteSpace(Answers.TargetProvince) ? "Not specified" : Answers.TargetProvince)</span>
            </div>
            <div class="stat-chip">
                <span class="stat-label">Estimated Timeline</span>
                <span class="stat-val">@(string.IsNullOrWhiteSpace(Result.Roadmap?.EstimatedTotalTimeline) ? "—" : Result.Roadmap!.EstimatedTotalTimeline)</span>
            </div>
            <div class="stat-chip">
                <span class="stat-label">Estimated Cost</span>
                <span class="stat-val">@(string.IsNullOrWhiteSpace(Result.Roadmap?.EstimatedTotalCost) ? "—" : Result.Roadmap!.EstimatedTotalCost)</span>
            </div>
        </div>
    </div>

    @if (Result.Roadmap is not null)
    {
        <div class="section-card">
            @if (!string.IsNullOrWhiteSpace(Result.Roadmap.RecommendedPathway))
            {
                <div class="recommended-pathway">
                    <span class="rp-label">Recommended pathway</span>
                    <div class="rp-value">@Result.Roadmap.RecommendedPathway</div>
                </div>
            }

            @if (Phases.Count > 0)
            {
                <div class="phases-head">
                    <h2 class="phases-title">Your Journey Phases</h2>
                    <span class="phases-progress">@_checked.Count of @TotalSteps steps complete</span>
                </div>
                <div class="pathway-progress-track">
                    <div class="pathway-progress-fill" style="width:@ProgressPercent%"></div>
                </div>
            }

            @{ var idx = 0; }
            @foreach (var phase in Phases)
            {
                idx++;
                var color = PhaseColors[(idx - 1) % PhaseColors.Length];
                <div class="phase-card" style="border-left-color:@color">
                    <div class="phase-head">
                        <div class="phase-num" style="background:@color">@idx</div>
                        <div class="phase-head-text">
                            <h3 class="phase-title">@phase.Title</h3>
                            @if (!string.IsNullOrWhiteSpace(phase.Description))
                            {
                                <div class="phase-desc">@phase.Description</div>
                            }
                        </div>
                    </div>
                    <div class="phase-steps">
                        @{ var stepNumber = 0; }
                        @foreach (var step in phase.Steps ?? new())
                        {
                            stepNumber++;
                            var key = $"{idx}:{stepNumber}:{step.Title}";
                            var done = _checked.Contains(key);
                            var stepCls = done ? "step-item done" : "step-item";
                            <label class="@stepCls">
                                <input type="checkbox" checked="@done" disabled="@ReadOnly" @onchange="@(() => ToggleStep(key))" />
                                <div class="step-body">
                                    <div class="step-title">@step.Title</div>
                                    @if (!string.IsNullOrWhiteSpace(step.Description))
                                    {
                                        <div class="step-desc">@step.Description</div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(step.EstimatedTimeline) || !string.IsNullOrWhiteSpace(step.EstimatedCost))
                                    {
                                        <div class="step-meta">
                                            @if (!string.IsNullOrWhiteSpace(step.EstimatedTimeline))
                                            {
                                                <span class="step-meta-item"><strong>Timeline:</strong> @step.EstimatedTimeline</span>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(step.EstimatedCost))
                                            {
                                                <span class="step-meta-item"><strong>Cost:</strong> @step.EstimatedCost</span>
                                            }
                                        </div>
                                    }
                                </div>
                            </label>
                        }
                    </div>
                </div>
            }

            @if (Notes.Count > 0)
            {
                <div class="notes-card">
                    <h3 class="notes-title">Important notes</h3>
                    <ul class="notes-list">
                        @foreach (var note in Notes)
                        {
                            <li>@note</li>
                        }
                    </ul>
                </div>
            }
        </div>
    }
    else
    {
        <div class="section-card">
            <p class="hint">The AI returned a response we couldn't format automatically. Here is the raw output:</p>
            <pre class="raw-text">@Result.RawText</pre>
        </div>
    }

    <details class="what-sent no-print">
        <summary>What was sent to the AI</summary>
        <div class="what-sent-body">
            <h4>Editable system instruction</h4>
            <pre>@Result.SystemInstruction</pre>
            <p class="schema-note">A fixed roadmap JSON schema and concise output limits were also enforced automatically so tuning cannot break the result layout.</p>
            <h4>User message</h4>
            <pre>@Result.UserMessage</pre>
            @if (Attachments.Count > 0)
            {
                <h4>Knowledge-base files</h4>
                <div class="attach-list">
                    @foreach (var a in Attachments)
                    {
                        <div class="attach-item">
                            <span class="attach-badge @(a.Sent ? "" : "not-sent")">@(a.Sent ? a.Kind : "not sent")</span>
                            <span class="attach-name">@a.FileName</span>
                            <span class="attach-note">@a.SizeDisplay@(string.IsNullOrEmpty(a.Note) ? "" : $" — {a.Note}")</span>
                        </div>
                    }
                </div>
            }
            <div class="what-sent-meta">
                Model: @ModelCatalog.DisplayName(Result.Model) · effort: @EffortDisplay · maximum output: @Result.MaxOutputTokens.ToString("N0") tokens · reference files: @(Result.IncludeKnowledgeBase ? "enabled" : "disabled")<br />
                Usage: @Usage.InputTokens.ToString("N0") in / @Usage.OutputTokens.ToString("N0") out tokens · estimated cost @Result.CostUsd.ToString("C4")
            </div>
        </div>
    </details>

    @if (_pendingAction is not null)
    {
        <div class="replacement-warning no-print" role="alert">
            <div>
                <strong>@PendingTitle</strong>
                <span>@PendingMessage</span>
            </div>
            <div class="replacement-actions">
                <button class="btn-prev" @onclick="CancelPending">Cancel</button>
                <button class="btn-next" @onclick="ConfirmPending">Continue</button>
            </div>
        </div>
    }

    <div class="roadmap-actions no-print">
        <button class="btn-prev" @onclick="Print">Print / Save as PDF</button>
        @if (!ReadOnly)
        {
            <button class="btn-prev" @onclick="RequestEdit">Edit answers</button>
            <button class="btn-next" @onclick="RequestRegenerate">Regenerate</button>
            <button class="btn-generate" @onclick="RequestStartOver">Start over</button>
        }
    </div>

    <div class="roadmap-document-meta">
        Generated @GeneratedDisplay · Questionnaire v@(Result.QuestionnaireVersion) · Draft - pending advisor review
    </div>
</div>

@code {
    [Parameter] public RoadmapResult Result { get; set; } = new();
    [Parameter] public AssessmentAnswers Answers { get; set; } = new();
    [Parameter] public EventCallback OnRegenerate { get; set; }
    [Parameter] public EventCallback OnEditAnswers { get; set; }
    [Parameter] public EventCallback OnStartOver { get; set; }
    [Parameter] public bool ReadOnly { get; set; }

    // When the host supplies a shared set (the wizard does), ticked steps survive navigation.
    // History's read-only view supplies none, so it uses its own throwaway set.
    [Parameter] public HashSet<string>? CheckedSteps { get; set; }
    private readonly HashSet<string> _checkedLocal = new();
    private HashSet<string> _checked => CheckedSteps ?? _checkedLocal;
    private static readonly string[] PhaseColors = { "#16a34a", "#7c3aed", "#2563eb", "#ea580c", "#0891b2", "#db2777" };

    // Null-safe views over the roadmap so a stray null collection (from the model, or an old
    // history snapshot) can never throw during render.
    private List<PhaseDto> Phases => Result.Roadmap?.Phases?.OfType<PhaseDto>().ToList() ?? new();
    private List<string> Notes => Result.Roadmap?.Notes?.OfType<string>().ToList() ?? new();
    private List<AttachmentInfo> Attachments => Result.Attachments ?? new();
    private TokenUsage Usage => Result.Usage ?? new();

    private int TotalSteps => Phases.Sum(p => p.Steps?.Count ?? 0);
    private int ProgressPercent => TotalSteps == 0 ? 0 :
        (int)Math.Round(Math.Min(_checked.Count, TotalSteps) / (double)TotalSteps * 100);

    private void ToggleStep(string key)
    {
        if (ReadOnly) return;
        if (!_checked.Remove(key)) _checked.Add(key);
    }

    private string EffortDisplay => ModelCatalog.Find(Result.Model).SupportsEffort
        ? Result.Effort
        : "model default";

    private string GeneratedDisplay => DateTime.TryParse(Result.GeneratedAtUtc, null,
        System.Globalization.DateTimeStyles.RoundtripKind, out var dt)
            ? dt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")
            : "for this assessment";

    private string? _pendingAction;
    private string PendingTitle => _pendingAction == "start" ? "Start over?" : "Replace this pathway?";
    private string PendingMessage => _pendingAction == "start"
        ? "This clears the current answers and pathway. The saved History snapshot remains available."
        : $"A replacement pathway will reset {_checked.Count} checked step{(_checked.Count == 1 ? "" : "s")}. The current snapshot remains available in History.";

    private Task RequestEdit() => RequestAction("edit", OnEditAnswers);
    private Task RequestRegenerate() => RequestAction("regenerate", OnRegenerate);
    private Task RequestStartOver() => RequestAction("start", OnStartOver, alwaysConfirm: true);

    private async Task RequestAction(string action, EventCallback callback, bool alwaysConfirm = false)
    {
        if (alwaysConfirm || _checked.Count > 0)
        {
            _pendingAction = action;
            return;
        }
        await callback.InvokeAsync();
    }

    private void CancelPending() => _pendingAction = null;

    private async Task ConfirmPending()
    {
        var action = _pendingAction;
        _pendingAction = null;
        if (action == "edit") await OnEditAnswers.InvokeAsync();
        else if (action == "regenerate") await OnRegenerate.InvokeAsync();
        else if (action == "start") await OnStartOver.InvokeAsync();
    }

    private async Task Print() => await JS.InvokeVoidAsync("window.print");
}
